<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F5">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottomNavLayout"
        android:clipToPadding="false"
        android:paddingBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="স্বাগতম, Shahid!"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="আজকের বিক্রির আপডেট দেখুন"
                        android:textColor="#757575" />
                </LinearLayout>

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/ivProfileEdit"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:layout_alignParentEnd="true"
                    android:padding="2dp"
                    android:src="@android:drawable/ic_menu_edit"
                    android:background="#E1E1E1"
                    app:strokeColor="#FFFFFF"
                    app:strokeWidth="2dp" />
            </RelativeLayout>

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:alignmentMode="alignMargins"
                android:columnOrderPreserved="false">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="#E3F2FD">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="আজকের বিক্রি"
                            android:textColor="#1976D2" />
                        <TextView
                            android:id="@+id/tvTodaySales"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="৳ ০.০০"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="#0D47A1" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="#E8F5E9">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="আজকের জমা"
                            android:textColor="#2E7D32" />
                        <TextView
                            android:id="@+id/tvTodayPaid"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="৳ ০.০০"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="#1B5E20" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="#F1F8E9">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="আজকের টার্গেট"
                            android:textColor="#388E3C" />
                        <TextView
                            android:id="@+id/tvTodayTarget"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="৳ ০.০০"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="#1B5E20" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="#FFF5F5">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="মোট বকেয়া"
                            android:textColor="#D32F2F" />
                        <TextView
                            android:id="@+id/tvTotalDueAmount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="৳ ০.০০"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="#B71C1C" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </GridLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="অ্যাকশন এবং রিপোর্টস"
                android:layout_marginTop="16dp"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="#1A1A1A"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSell"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="12dp"
                android:text="নতুন বিক্রি শুরু করুন"
                android:textSize="16sp"
                app:icon="@drawable/sell"
                app:cornerRadius="12dp"
                android:backgroundTint="#FF5722" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOrderHistory"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="8dp"
                android:text="অর্ডার হিস্টোরি"
                app:icon="@android:drawable/ic_menu_agenda"
                app:cornerRadius="12dp"
                android:backgroundTint="#1976D2"
                style="@style/Widget.MaterialComponents.Button.Icon" />


            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnShopManagement"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="8dp"
                android:text="দোকান ম্যানেজমেন্ট"
                app:icon="@android:drawable/ic_menu_myplaces"
                app:cornerRadius="12dp"
                android:backgroundTint="#1976D2" />

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/bottomNavLayout"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_alignParentBottom="true"
        android:background="@color/white"
        android:elevation="12dp"
        android:orientation="horizontal"
        android:weightSum="3">

        <LinearLayout
            android:id="@+id/btnHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:background="?attr/selectableItemBackground"
            android:orientation="vertical">
            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@android:drawable/ic_menu_today"
                app:tint="#FF5722" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="হোম"
                android:textColor="#FF5722"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnGoToCart"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:background="?attr/selectableItemBackground"
            android:orientation="vertical">
            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@android:drawable/ic_input_add"
                app:tint="#555555" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="কার্ট"
                android:textColor="#555555"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:background="?attr/selectableItemBackground"
            android:orientation="vertical">
            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@android:drawable/ic_menu_myplaces"
                app:tint="#555555" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="প্রোফাইল"
                android:textColor="#555555"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

</RelativeLayout>